        <div class="email-container">
            <div class="header">
            <h1>A bold beginning awaits</h1>
            <div class="hero-image-placeholder">
                <img src="https://itan-bucket-storage.s3.eu-north-1.amazonaws.com/email-img.jpg" alt="ITAN Book Collection" class="hero-image">
            </div>
